generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum UserRole {
  USER
  ADMIN
}

enum MatchFormat {
  BO3
  BO5
  BO7
}

enum MatchGroup {
  MPLID
  MPLPH
  MPLMY
}

// ═══════════════════════════════════════════════════════════════
// AUTHENTICATION & USER MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          UserRole  @default(USER)
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?

  favoriteTeamId Int?
  favoriteTeam   Team? @relation("FavoriteTeam", fields: [favoriteTeamId], references: [id], onDelete: SetNull)

  // Relations
  sessions          Session[]
  accounts          Account[]
  predictions       UserPrediction[]
  playoffPredictions UserPlayoffPrediction[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_accounts")
}

model Verification {
  id        String    @id @default(uuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  identifier String
  value      String
  expiresAt  DateTime

  @@map("verifications")
}

// ═══════════════════════════════════════════════════════════════
// MATCH MANAGEMENT
// ═══════════════════════════════════════════════════════════════

model Team {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  logo  String?
  group MatchGroup @default(MPLID)

  matchesAsA Match[] @relation("TeamA")
  matchesAsB Match[] @relation("TeamB")
  playoffMatchesAsA PlayoffMatch[] @relation("PlayoffTeamA")
  playoffMatchesAsB PlayoffMatch[] @relation("PlayoffTeamB")
  favoritedBy User[] @relation("FavoriteTeam")

  @@map("teams")
}

model Match {
  id      Int         @id @default(autoincrement())
  week    Int
  day     Int
  date    DateTime
  teamAId Int
  teamBId Int
  format  MatchFormat @default(BO3)
  group   MatchGroup  @default(MPLID)
  matchNo Int         @default(1)

  // Actual results (set by admin)
  teamAResult Int?
  teamBResult Int?

  teamA Team @relation("TeamA", fields: [teamAId], references: [id])
  teamB Team @relation("TeamB", fields: [teamBId], references: [id])

  predictions UserPrediction[]

  @@index([week, day])
  @@map("matches")
}

model PlayoffMatch {
  id        Int         @id @default(autoincrement())
  matchId   String      // e.g. "UBQ1", "UBQ2", "UBS1", "UBS2", "UBF", "LBSF", "LBF", "GF"
  group     MatchGroup  @default(MPLID)
  
  teamAId   Int?
  teamBId   Int?
  teamA     Team?       @relation("PlayoffTeamA", fields: [teamAId], references: [id])
  teamB     Team?       @relation("PlayoffTeamB", fields: [teamBId], references: [id])
  
  teamAResult Int?
  teamBResult Int?
  
  format    MatchFormat @default(BO5)
  date      DateTime?
  
  predictions UserPlayoffPrediction[]

  @@unique([group, matchId])
  @@map("playoff_matches")
}

// ═══════════════════════════════════════════════════════════════
// USER PREDICTIONS
// ═══════════════════════════════════════════════════════════════

model UserPrediction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId  String
  matchId Int

  teamAPrediction Int?
  teamBPrediction Int?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId]) // one prediction per user per match
  @@index([userId])
  @@index([matchId])
  @@map("user_predictions")
}

model UserPlayoffPrediction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId         String
  playoffMatchId Int

  teamAPrediction Int?
  teamBPrediction Int?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  playoffMatch PlayoffMatch @relation(fields: [playoffMatchId], references: [id], onDelete: Cascade)

  @@unique([userId, playoffMatchId])
  @@index([userId])
  @@index([playoffMatchId])
  @@map("user_playoff_predictions")
}
