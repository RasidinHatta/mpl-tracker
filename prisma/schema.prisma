generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id         Int     @id @default(autoincrement())
  name       String  @unique
  logo       String?
  matchesAsA Match[] @relation("TeamA")
  matchesAsB Match[] @relation("TeamB")
}

model Match {
  id              Int         @id @default(autoincrement())
  week            Int
  day             Int
  date            DateTime
  teamAId         Int
  teamBId         Int
  teamAPrediction Int?
  teamAResult     Int?
  teamBPrediction Int?
  teamBResult     Int?
  format          MatchFormat @default(BO3)
  matchNo         Int         @default(1)
  teamA           Team        @relation("TeamA", fields: [teamAId], references: [id])
  teamB           Team        @relation("TeamB", fields: [teamBId], references: [id])
}

enum MatchFormat {
  BO3
  BO5
  BO7
}
